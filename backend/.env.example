# 复制为 .env 后修改

# LLM（OpenAI 兼容，如 DeepSeek）
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.deepseek.com

# Neo4j（图谱问答；账号建议仅含读权限）
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
# 为 true 时启动后尝试从库刷新 schema（需 APOC 等）；为 false 则使用代码内手工 schema
NEO4J_REFRESH_SCHEMA=false
NEO4J_QUERY_TIMEOUT=30
# 为 true 时拒绝含 CALL 的 Cypher（更严，可能误伤只读过程）
CYPHER_BLOCK_CALL=false

# 管理接口：非空时 POST /api/admin/cache/invalidate 需 Header X-Admin-Key
ADMIN_API_KEY=

# 问答缓存（条数与 TTL 秒，最大条目 0 表示关闭）
QA_CACHE_MAX_ENTRIES=256
QA_CACHE_TTL_SECONDS=3600
QA_USE_SIMPLE_TEMPLATE=true

# 数据目录（默认 backend/data）
# DATA_DIR=data
